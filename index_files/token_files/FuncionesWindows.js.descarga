function openWin(url, Usuario, nombreUsuario, Maquina, Token,
                    Empresa, nombreEmpresa, Sucursal, identSucursal, nombreSucursal,
                    IdentEmpresa, OpidentEmpresa, OpidentSucursal, UsuarioAnterior) {
    var d = new Date();
    
    winName = 'win' + d.getMilliseconds();
    win = window.open("", winName, 'toolbar=yes,location=yes,directories=yes,menubar=yes,scrollbars=yes,status=yes,resizable=1');
    win.document.write("<form name='aform' method='post' action='" + url + "'>");
    win.document.write("<input type='text' style='width: 0px; border: none;' name='IdUsuario'>");
    win.document.write("<input type='text' style='width: 0px; border: none;' name='NombreUsuario'>");
    win.document.write("<input type='text' style='width: 0px; border: none;' name='Maquina'>");
    win.document.write("<input type='text' style='width: 0px; border: none;' name='Token'>");
    win.document.write("<input type='text' style='width: 0px; border: none;' name='IdEmpresa'>");
    win.document.write("<input type='text' style='width: 0px; border: none;' name='NombreEmpresa'>");
    win.document.write("<input type='text' style='width: 0px; border: none;' name='IdSucursal'>");
    win.document.write("<input type='text' style='width: 0px; border: none;' name='IdentSucursal'>");
    win.document.write("<input type='text' style='width: 0px; border: none;' name='NombreSucursal'>");
    win.document.write("<input type='text' style='width: 0px; border: none;' name='IdentEmpresa'>");
    win.document.write("<input type='text' style='width: 0px; border: none;' name='OpidentEmpresa'>");
    win.document.write("<input type='text' style='width: 0px; border: none;' name='OpidentSucursal'>");
    win.document.write("<input type='text' style='width: 0px; border: none;' name='IdUsuarioAnterior'>");

    win.document.write("</form>");
    win.document.aform.IdUsuario.value = Usuario;
    win.document.aform.NombreUsuario.value = nombreUsuario;
    win.document.aform.Maquina.value = Maquina;
    win.document.aform.Token.value = Token;
    win.document.aform.IdEmpresa.value = Empresa;
    win.document.aform.NombreEmpresa.value = nombreEmpresa;
    win.document.aform.IdSucursal.value = Sucursal;
    win.document.aform.IdentSucursal.value = identSucursal;
    win.document.aform.NombreSucursal.value = nombreSucursal;
    win.document.aform.IdentEmpresa.value = IdentEmpresa;
    win.document.aform.OpidentEmpresa.value = OpidentEmpresa;
    win.document.aform.OpidentSucursal.value = OpidentSucursal;
    win.document.aform.IdUsuarioAnterior.value = UsuarioAnterior;
    win.document.aform.submit();

}

function Check_Cantidad(value) {
    var Newvalue = value + String.fromCharCode(event.keyCode);
    if ((Newvalue != "-") && isNaN(Newvalue)) {
        if (isNaN(String.fromCharCode(event.keyCode)) ||
							String.fromCharCode(event.keyCode) == ".") {
            event.returnValue = false;
        }
    }
    //no permite ingresar negativos
    if (String.fromCharCode(event.keyCode) == "-") {
        event.returnValue = false;
    }
}
function validarNumAlfN(e, maxL) {
    if (maxL.maxLength > 100 || maxL.maxLength == -1)
        return true;
    tecla = (document.all) ? e.keyCode : e.which;
    if (tecla == 8 || tecla == 9 || tecla == 46 || tecla == 16) return true;
    if (tecla >= 65 && tecla <= 90) return true;
    if (tecla >= 48 && tecla <= 57) return true;
    if (tecla >= 96 && tecla <= 105) return true; //tecla = tecla - 48;
    return false;
}

function pause(milisg) {
    d = new Date() //today's date
    while (1) {
        mill = new Date() // Date Now
        diff = mill - d //difference in milliseconds
        if (diff > milisg) { break; }
    }
}

function CloseWindowX() {
   
    if ((window.event.clientY < 0 && window.event.clientY >= -30
			&& window.event.clientX >= document.body.offsetWidth - 30
			&& window.event.clientX <= document.body.offsetWidth)
			&& (document.forms[0].name != "frmSalir")) //Para saber que se cierra el browser desde cualquier parte
    {
        
    }
}

function BtnDesabled() {
    var arrBtn;
    //Deshabilita todos los botones una vez que se presiono Click
    arrBtn = document.getElementsByTagName("input");
    for (i = 0; i < arrBtn.length; i++) {
        obj = arrBtn[i];
        if (obj.type == "image" && obj.name.toUpperCase().indexOf("BTN") >= 0) {
           
            obj.onclick = new Function("return false;"); //para que deshabilite el click
        }
    }
}

function OnClick() {
    if (document.parentWindow.event.srcElement.name != null) {
        var ev = document.parentWindow.event; //Recupera el elemento que produjo el evento click
        if (ev.srcElement.name.toUpperCase().indexOf("BTN") >= 0)
            BtnDesabled();
    }
}



function nothing() {
   
    new Function("return false;");
}

function Salir() {
   
    window.opener = "Inicial";
    window.close();
}
function SalirPadre() {
   
    parent.window.opener = "Inicial";
    parent.window.close();
}


