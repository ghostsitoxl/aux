function msgConfirma(obj, msg, id) {
    //debugger;
    if (confirm(msg)) {
        objeto = document.getElementById("ctl00_ContentPlaceHolder1_objCtlBarraCmd_txtComando");
        if (objeto == null)
            objeto = document.getElementById(obj); //En caso de no migrado el BarraCmd
        objeto.value = id;
        document.forms[0].submit();
    }

}

function SetimgButtonEnabled(imgBtn, estado) {
    //debugger;
    if (estado) {
        document.getElementById(imgBtn).onclick = new Function();
    }
    else {
        document.getElementById(imgBtn).onclick = new Function("return false;");
    }
}
function SetimgButtonDefault(imgBtnEnter) {
    if (window.event != null) {
        switch (event.keyCode) {
            case 13: //Enter
                event.returnValue = false;
                event.cancel = true;
                obj = document.getElementById(imgBtnEnter);
                if (obj != null)
                    obj.click();
                
                break;
           

        }
    }
    
}


function AbrirWindow(formulario, arg, ancho, alto, margenS, margenI) {

    var nombre = "frm";
    var temp = new Date();

    var w = 480, h = 340;
    if (document.all || document.layers) {
        w = screen.availWidth;
        h = screen.availHeight;
    }
    if (margenS == -1)
        margenS = (w - ancho) / 2;
    if (margenI == -1)
        margenI = (h - alto) / 2;

    nombre += temp.getHours();
    nombre += temp.getMinutes();
    nombre += temp.getSeconds();
    nombre += temp.getMilliseconds();
    window.open(formulario, nombre, "width=" + ancho + ", height=" + alto + ", left=" + margenI + ", top=" + margenS + ", menubar=no, titlebar=no, location=no, status=yes, toolbar=no, scrollbars=yes, resizable=yes");
    switch (arg) {
        case 0:
            Salir(); break;
        case 1: break;
        case 2: SalirPadre(); break;
    }

}

function AbrirWindow2(formulario, arg, ancho, alto, margenS, margenI) {
    console.log("entro metodo abrir window2");
    var nombre = "frm";
    var temp = new Date();

    var w = 480, h = 340;
    if (document.all || document.layers) {
        w = screen.availWidth;
        h = screen.availHeight;
    }
    if (margenS == -1)
        margenS = (w - ancho) / 2;
    if (margenI == -1)
        margenI = (h - alto) / 2;

    nombre += temp.getHours();
    nombre += temp.getMinutes();
    nombre += temp.getSeconds();
    nombre += temp.getMilliseconds();
    var closeWindowNuevo=false;
    var nuevaVentana = window.open(formulario, nombre, "width=" + ancho + ", height=" + alto  +"opacity=1" + ", left=" + margenI + ", top=" + margenS + ", menubar=no, titlebar=no, location=no, status=yes, toolbar=no, scrollbars=yes, resizable=yes");
    setTimeout(function() {
        if (nuevaVentana && !closeWindowNuevo) {
            closeWindowNuevo = true;
            //alert('El archivo se descargo!');
            nuevaVentana.close();
        }
    }, 1000);
    setTimeout(function() {
        if (nuevaVentana && !closeWindowNuevo) {
            closeWindowNuevo = true;
            //alert('El archivo se descargo!');
            nuevaVentana.close();
        }
    }, 2000);
    setTimeout(function() {
        if (nuevaVentana && !closeWindowNuevo) {
            closeWindowNuevo = true;
            //alert('El archivo se descargo!');
            nuevaVentana.close();
        }
    }, 3000);
    setTimeout(function() {
        if (nuevaVentana && !closeWindowNuevo) {
            closeWindowNuevo = true;
            //alert('El archivo se descargo!');
            nuevaVentana.close();
        }
    }, 4000);
}

function AbrirWindowModal(nombre, formulario, arg, ancho, alto, margenS, margenI) {
    if (arg == 0) {
        window.open(formulario, nombre, "width=" + ancho + ", height=" + alto + ", left=" + margenI + ", top=" + margenS + ", menubar=no, titlebar=no, location=no, status=yes, toolbar=no, scrollbars=yes, resizable=yes");
        Salir();
    }
    else {
        window.open(formulario, nombre, "width=" + ancho + ", height=" + alto + ", left=" + margenI + ", top=" + margenS + ", menubar=no, titlebar=no, location=no, status=yes, toolbar=no, scrollbars=yes, resizable=yes");
    }

}

