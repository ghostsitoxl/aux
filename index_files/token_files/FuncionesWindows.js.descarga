function CheckCurrency(Obj, SeparadorNum, SeparadorDec, Signo) {
    var Val = Obj.value;
    var Result = true;
    //Valida solo numeros, separador decimal y signo '-'
    if (String.fromCharCode(event.keyCode) == " "
		|| (isNaN(String.fromCharCode(event.keyCode))
			&& String.fromCharCode(event.keyCode) != SeparadorDec
			&& String.fromCharCode(event.keyCode) != SeparadorNum
			&& String.fromCharCode(event.keyCode) != "-")) {
        Result = false;
    }
    //no permite ingresar mas de un separador decimal
    if ((String.fromCharCode(event.keyCode) == SeparadorDec && Val.indexOf(SeparadorDec) >= 0)
		|| (String.fromCharCode(event.keyCode) == "-" && (Val.indexOf("-") >= 0 || Signo != true))) {
        Result = false;
    }

    // controla en ingreso del signo '-'
    if (String.fromCharCode(event.keyCode) == "-" && Val.indexOf("-") == -1 && Signo == true) {
        Result = false;
        Obj.value = '-' + Val;
    }
    event.returnValue = Result;
}

//******************************************************
/*
Funciones para los Botones Numericos de Ingreso de Clave
*/
//******************************************************
function IniBtnKeyPad() {
    IniBtnKeyPadID("");
}
function IniBtnKeyPadID(sID) {
    NameBtn = "btnKeyPad";
    sec = "0123456789";
    var iR = 0;
    for (i = 0; i < 21; i++) {
        iR = Math.floor(Math.random() * 10);
        sec = iR + sec.replace(iR, "");
    }
    for (i = 0; i < 10; i++) {
        obj = document.getElementById(NameBtn + i + sID);
        if (obj.tagName == "IMG") {
            obj.src = "../imagenes/" + sec.substring(i, i + 1) + ".jpg";
            obj.style.cursor = "hand";
        }
    }

    oNomOClave = document.getElementById("objNomOClv" + sID);
    obj2 = document.getElementById(oNomOClave.value);
    obj2.value = "";
}
function setVal(objN) {
    var sIdT = "";
    if (objN.id.substring(0, 9) == "btnBorrar") {
        if (objN.id.length > 9)
            sIdT = objN.id.substring(9, objN.id.length + 1);
    }
    else {
        if (objN.id.length > 10)//btnKeyPad0
            sIdT = objN.id.substring(10, objN.id.length + 1);
    }
    setValID(objN, sIdT);
    return false;
}
function setValID(objN, sID) {
    //iMaxLen = 10;
    oNomText = document.getElementById("objNomTxt" + sID);
    obj = document.getElementById(oNomText.value);
    iMaxLen = obj.getAttribute("maxlength");

    sVal = objN.src;
    sVal = sVal.substring(sVal.length - 5, sVal.length - 4);
    if (sVal == "r") {
        obj.value = "";
    }
    else {
        if (obj.value.length == iMaxLen)
            return false;

        obj.value = obj.value + sVal;
    }

    oNomOClave = document.getElementById("objNomOClv" + sID);
    obj2 = document.getElementById(oNomOClave.value);
    obj2.value = obj.value;

    return false;
}
