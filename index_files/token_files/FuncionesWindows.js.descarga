}

function Search_OnBlur(id, valor) {
    //Llama a buscar document.frmRol.item(objeto);
    obj = document.getElementById("ctl00_ContentPlaceHolder1_objCtlBarraCmd_txtConsulta");
    if (obj == null)
        obj = document.getElementById("txtConsulta"); //En caso de no migrado BarraCmd
    if (valor != "") {
        obj.value = "F" + id;
        document.forms[0].submit();
    }
}
//VALIDA INGRESO DE VALORES NUMERICOS: OnKeyPress
function CheckNumber(Obj, Separador, Signo) {
    var Val = Obj.value;
    var Result = true;
    //Valida solo numeros, separador decimal y signo '-'
    if (String.fromCharCode(event.keyCode) == " "
		|| (isNaN(String.fromCharCode(event.keyCode))
			&& String.fromCharCode(event.keyCode) != Separador
			&& String.fromCharCode(event.keyCode) != "-")) {
        Result = false;
    }
    //no permite ingresar mas de un separador decimal
    if ((String.fromCharCode(event.keyCode) == Separador && Val.indexOf(Separador) >= 0)
		|| (String.fromCharCode(event.keyCode) == "-" && (Val.indexOf("-") >= 0 || Signo != true))) {
        Result = false;
    }
    // controla en ingreso del signo '-'
    if (String.fromCharCode(event.keyCode) == "-" && Val.indexOf("-") == -1 && Signo == true) {
        Result = false;
        Obj.value = '-' + Val;
    }
    event.returnValue = Result;
}

//VALIDA INGRESO DE NUMEROS,LETRAS y ESPACIO : OnKeyPress
function CheckAlphaNumber(Obj, Separador, Signo) {
    var Val = Obj.value;
    var Result = true;
    //Valida solo numeros, separador decimal y signo '-'
    if ((isNaN(String.fromCharCode(event.keyCode)) && String.fromCharCode(event.keyCode) != " ")) {
        Result = false;
    }
    if (!(/[^a-zA-Z0-9]/.test(Val))) {
        Result = false;
    }
    // controla en ingreso del signo '-'
    if (String.fromCharCode(event.keyCode) == "-" && Val.indexOf("-") == -1 && Signo == true) {
        Result = false;
        Obj.value = '-' + Val;
    }
    event.returnValue = Result;
}

function ValidaEspacioBlanco(value) {
    if (String.fromCharCode(event.keyCode) == " ") {
        event.returnValue = false;
    }
}

