window.onload = function() {
    getBrowserName();
};

function getBrowserName() {
    const userAgent = navigator.userAgent;
    let browserName = "Unknown";

    if (userAgent.indexOf("Firefox") > -1) {
        document.getElementById("bdaMainContent").style.position = "relative";
		let elementos = document.getElementsByClassName("footer-text");
		for (let i = 0; i < elementos.length; i++) {
			elementos[i].style.position = "fixed";
			break;
		}
		
        browserName = "Mozilla Firefox";
    } else if (userAgent.indexOf("Chrome") > -1) {
        browserName = "Google Chrome";
    }

    return browserName;
}

function EjecutaCmd(Argumento) {
  
    //Funcion que invoca a un ejecutable pasando xml de seccion como argumento
    var shell = new ActiveXObject("WScript.Shell");
    shell.run(Argumento);
   
}

