function RedirSitio(url) {
    //const spinnerElement = document.getElementById("mainSpinner");
    //spinnerElement.style.display = "block";
    //console.log("RedirSitio: ", url);
    var objSitio;
    var obj;
    obj = document.getElementById("objFrame");
    obj.innerHTML = "<iframe allow='clipboard-read *; clipboard-write *' marginheight='0' marginwidth ='0'  frameborder='0' src='' id='OtroSitio' name='OtroSitio' width='100%' style='height: 100%;'></iframe>";

    objSitio = document.getElementById("OtroSitio");
    objSitio.contentWindow.document.clear();

    objSitio.contentWindow.document.write("<html><head><style>");
    objSitio.contentWindow.document.write("body { width: 100%; height: 100%; padding: 1rem; } .spinner { border: 4px solid rgba(0, 0, 0, 0.1); width: 36px; height: 36px; border-radius: 50%; border-left-color: #00166a; animation: spin 1s ease infinite; } @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }");
    objSitio.contentWindow.document.write("</style></head><body>");
    
    objSitio.contentWindow.document.write("<div style='width: -webkit-fill-available; position: fixed; left: 50%;'> <div class='spinner'></div> </div>");



    if (url.indexOf(".htm") > 0)
        objSitio.contentWindow.document.write("<form name='aform' action='" + url + "' style='display: none;' >");
    else
        objSitio.contentWindow.document.write("<form name='aform' method='post' action='" + url + "' style='display: none;' >");


    objSitio.contentWindow.document.write("<input type='text' style='width: 0px; border: none;' name='IdUsuario' id='IdUsuario' >");
    objSitio.contentWindow.document.write("<input type='text' style='width: 0px; border: none;' name='Identificacion' id='Identificacion'>");
    objSitio.contentWindow.document.write("<input type='text' style='width: 0px; border: none;' name='TipoIdentificacion' id='TipoIdentificacion'>");
    objSitio.contentWindow.document.write("<input type='text' style='width: 0px; border: none;' name='NombreUsuario' id='NombreUsuario'>");
    objSitio.contentWindow.document.write("<input type='text' style='width: 0px; border: none;' name='Maquina' id='Maquina'>");
    objSitio.contentWindow.document.write("<input type='text' style='width: 0px; border: none;' name='Token' id='Token'>");
    objSitio.contentWindow.document.write("<input type='text' style='width: 0px; border: none;' name='IdEmpresa' id='IdEmpresa'>");
    objSitio.contentWindow.document.write("<input type='text' style='width: 0px; border: none;' name='NombreEmpresa' id='NombreEmpresa'>");
    objSitio.contentWindow.document.write("<input type='text' style='width: 0px; border: none;' name='IdSucursal' id='IdSucursal'>");
    objSitio.contentWindow.document.write("<input type='text' style='width: 0px; border: none;' name='IdentSucursal' id='IdentSucursal'>");
    objSitio.contentWindow.document.write("<input type='text' style='width: 0px; border: none;' name='NombreSucursal' id='NombreSucursal'>");
    objSitio.contentWindow.document.write("<input type='text' style='width: 0px; border: none;' name='IdentEmpresa' id='IdentEmpresa'>");
    objSitio.contentWindow.document.write("<input type='text' style='width: 0px; border: none;' name='OpidentEmpresa' id='OpidentEmpresa'>");
    objSitio.contentWindow.document.write("<input type='text' style='width: 0px; border: none;' name='OpidentSucursal' id='OpidentSucursal'>");
    objSitio.contentWindow.document.write("<input type='text' style='width: 0px; border: none;' name='IdUsuarioAnterior' id='IdUsuarioAnterior'>");
    objSitio.contentWindow.document.write("</form>");
    objSitio.contentWindow.document.write("</body></html>");

    objSitio.contentWindow.document.getElementById("IdUsuario").value = document.getElementById("ctl00_objctrPie_IdUsuario").value;
